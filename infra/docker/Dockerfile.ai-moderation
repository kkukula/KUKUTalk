# syntax=docker/dockerfile:1.6
FROM node:20-alpine AS base
RUN corepack enable

FROM base AS deps
WORKDIR /repo
COPY package.json pnpm-workspace.yaml turbo.json pnpm-lock.yaml ./
COPY apps ./apps
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @kukutalk/ai-moderation build
RUN pnpm deploy --filter @kukutalk/ai-moderation --prod /opt/aimod

FROM base AS runner
ENV NODE_ENV=production \
    PORT=4001
WORKDIR /app
COPY --from=deps /opt/aimod/ /app/
EXPOSE 4001
CMD ["node","dist/index.js"]
