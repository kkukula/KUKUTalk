# syntax=docker/dockerfile:1.6
FROM node:20-alpine AS base
RUN corepack enable

FROM base AS deps
WORKDIR /repo
COPY package.json pnpm-workspace.yaml turbo.json pnpm-lock.yaml ./
COPY apps ./apps
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @kukutalk/ai-tutor build
RUN pnpm deploy --filter @kukutalk/ai-tutor --prod /opt/aitutor

FROM base AS runner
ENV NODE_ENV=production \
    PORT=4002
WORKDIR /app
COPY --from=deps /opt/aitutor/ /app/
EXPOSE 4002
CMD ["node","dist/index.js"]
