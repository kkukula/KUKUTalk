import { NestFactory } from '@nestjs/core';
import { AppModule } from './app.module';

async function bootstrap() {
  const app = await NestFactory.create(AppModule);


  
  const allow = (process.env.FRONTEND_ORIGINS ?? 'http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174')
    .split(',')
    .map(s => s.trim())
    .filter(Boolean);
  app.enableCors({ origin: allow, credentials: true });

  

  

  // === AUTH_EMAIL_MODE middleware (auto) ===
  // Tryby: 'disabled' (domyślny), 'both', 'emailonly'
  // Kolejność źródeł: plik (.auth_email_mode w kilku lokalizacjach) -> ENV AUTH_EMAIL_MODE -> 'disabled'
  const getAuthMode = (): 'disabled' | 'both' | 'emailonly' => {
    const fs = require('fs');
    const path = require('path');
    const candidates = [
      '.auth_email_mode',
      path.join(process.cwd?.() ?? '', '.auth_email_mode'),
      path.join(__dirname ?? '', '..', '..', '.auth_email_mode'),
      '/app/.auth_email_mode'
    ].filter(Boolean);
    for (const p of candidates) {
      try {
        if (fs.existsSync(p)) {
          const v = String(fs.readFileSync(p)).trim().toLowerCase();
          if (['disabled','both','emailonly'].includes(v)) return v as any;
        }
      } catch {}
    }
    const v = (process.env.AUTH_EMAIL_MODE ?? 'disabled').toLowerCase();
    return (['disabled','both','emailonly'].includes(v) ? (v as any) : 'disabled');
  };

  const { PrismaClient } = require('@prisma/client');
  const prismaAuth = new PrismaClient();

  // Upewnij się, że body jest sparsowane zanim wejdzie walidacja Nest (zwykle i tak jest),
  // ale na wszelki wypadek dodaj JSON parser jeśli nie istnieje.
  try {
    const express = require('express');
    app.use(express.json({ limit: '1mb' }));
  } catch {}

  app.use('/auth/login', async (req: any, res: any, next: any) => {
    const mode = getAuthMode();
    const b = (req.body ?? {});
    const hasEmail = typeof b.email === 'string' && b.email.length > 0;
    const hasUsername = typeof b.username === 'string' && b.username.length > 0;

    if (mode === 'disabled') {
      if (hasEmail) return res.status(400).json({ message: 'Email login disabled' });
      return next();
    }
    if (mode === 'emailonly' && !hasEmail) {
      return res.status(400).json({ message: 'Username login disabled; use email' });
    }

    if (hasEmail) {
      try {
        const user = await prismaAuth.user.findUnique({ where: { email: b.email } });
        if (!user) return res.status(401).json({ message: 'Invalid credentials' });
        // mapuj na username i usuń email, by kontroler/DTO nie wywalił 400
        b.username = user.username;
        delete b.email;
        req.body = b;
      } catch (e) {
        console.error('AUTH_EMAIL_MODE middleware error:', e);
        return res.status(500).json({ message: 'Auth preprocessing failed' });
      }
    }
    return next();
  });
  // === END AUTH_EMAIL_MODE (auto) ===
const PORT = Number(process.env.PORT) || 3001;
  await app.listen(PORT, '0.0.0.0');
  console.log(`API listening on http://0.0.0.0:${PORT}`);
}
bootstrap();





