{
  "name": "@kukutalk/api",
  "version": "0.1.0",
  "private": true,
  "description": "KUKUTalk API (NestJS + Prisma)",
  "main": "dist/main.js",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "schema": "infra/prisma/schema.prisma",
    "seed": "node prisma/seed.cjs"
  },
  "scripts": {
    "prebuild": "pnpm exec prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "db:seed": "pnpm exec prisma db seed",
    "postinstall": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.0.1",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/platform-socket.io": "^10.3.10",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.3.10",
    "@prisma/client": "5.22.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.10.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.12",
    "@types/passport-jwt": "^3.0.13",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
